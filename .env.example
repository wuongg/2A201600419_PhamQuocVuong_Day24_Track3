# cp .env.example .env

# --- Cloud OpenAI (mặc định khi không dùng local) ---
OPENAI_API_KEY=sk-...
COHERE_API_KEY=...

# Tuỳ chọn đặt tên model cloud (chat generation / judge).
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- LLM cục bộ (Ollama / LM Studio / vLLM — API kiểu OpenAI /v1) ---
# Bật khi có LOCAL_LLM_BASE_URL; không cần OPENAI_API_KEY cho chat/embed trong repo.
# LM Studio ví dụ:
# LOCAL_LLM_BASE_URL=http://127.0.0.1:1234/v1
# LOCAL_LLM_MODEL=qwen/qwen2.5-vl-7b
# LOCAL_LLM_API_KEY=lm-studio
# RAGAS + LM Studio: ít worker để tránh "No models loaded" (thử 1 nếu vẫn lỗi)
# RAGAS_MAX_WORKERS=1
# RAGAS_TIMEOUT=420
#
# Ollama ví dụ:
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_MODEL=qwen2.5:latest
# LOCAL_LLM_API_KEY=ollama
# Embedding cho RAGAS (answer_relevancy); có thể tách URL riêng:
# LOCAL_EMBEDDING_MODEL=nomic-embed-text
# LOCAL_EMBEDDING_BASE_URL=http://127.0.0.1:11434/v1

# Moderation guardrails dùng OpenAI API — full local nên tắt hoặc giữ key cloud riêng:
# LLAMA_GUARD_BACKEND=none

# --- Pipeline an toàn trên máy yếu / LM Studio / Windows ---
# SKIP_M5_ENRICHMENT=1
# SKIP_CROSS_ENCODER_RERANK=1
# PIPELINE_MAX_CONTEXT_CHARS=14000

# --- Tiết kiệm khi dev ---
# LAB_EVAL_LIMIT=8
# SKIP_NAIVE_BASELINE=1
# QDRANT_EMBEDDED=1
